generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Pharmacy {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  licenseNumber   String          @unique
  address         String
  city            String
  latitude        Float?
  longitude       Float?
  commissionRate  Float           @default(0.08)
  rating          Float           @default(0)
  status          PharmacyStatus  @default(ACTIVE)
  products        Product[]
  users           PharmacyUser[]
  pharmacyOrders  PharmacyOrder[]
  adminNotifications AdminNotification[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model PharmacyUser {
  id           String     @id @default(cuid())
  pharmacyId   String?
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(PHARMACY)
  active       Boolean    @default(true)
  pharmacy     Pharmacy?  @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  sessions     Session[]
  reviewedPrescriptions Prescription[] @relation("PrescriptionReviewer")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Session {
  id         String       @id @default(cuid())
  tokenHash  String       @unique
  userId     String
  expiresAt  DateTime
  user       PharmacyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
}

model Product {
  id                   String      @id @default(cuid())
  pharmacyId           String
  name                 String
  slug                 String      @unique
  routeKey             String
  scientificName       String?
  manufacturer         String?
  description          String
  dosage               String?
  form                 String?
  stock                Int         @default(0)
  price                Decimal
  discountPrice        Decimal?
  imageUrl             String?
  requiresPrescription Boolean     @default(false)
  featured             Boolean     @default(false)
  lowStockThreshold    Int         @default(10)
  active               Boolean     @default(true)
  tags                 String?
  categoryId           String?
  category             Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pharmacy             Pharmacy    @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  orderItems           OrderItem[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model CustomerOrder {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        OrderStatus  @default(PENDING)
  customerName  String
  customerEmail String
  phone         String
  address       String
  city          String
  deliveryLatitude  Float?
  deliveryLongitude Float?
  postalCode    String
  subtotal      Decimal
  shipping      Decimal
  total         Decimal
  paymentMethod String
  prescriptions Prescription[]
  pharmacyOrders PharmacyOrder[]
  assignmentEvents AssignmentEvent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PharmacyOrder {
  id               String        @id @default(cuid())
  customerOrderId   String
  pharmacyId        String
  status            PharmacyOrderStatus @default(PENDING)
  subtotal          Decimal
  shipping          Decimal
  total             Decimal
  commissionAmount  Decimal
  estimatedSlaMins  Int           @default(30)
  notes             String?
  customerOrder     CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  pharmacy          Pharmacy      @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  items             OrderItem[]
  prescription      Prescription?
  assignmentEvents  AssignmentEvent[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model OrderItem {
  id          String        @id @default(cuid())
  pharmacyOrderId String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal
  lineTotal   Decimal
  pharmacyOrder PharmacyOrder @relation(fields: [pharmacyOrderId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id])
}

model Prescription {
  id               String        @id @default(cuid())
  customerOrderId   String
  pharmacyOrderId   String?       @unique
  status           PrescriptionStatus @default(PENDING)
  fileName         String
  mimeType         String
  fileData         String
  customerName     String
  customerEmail    String
  customerPhone    String
  notes            String?
  reviewerId       String?
  reviewer         PharmacyUser? @relation("PrescriptionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  customerOrder    CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  pharmacyOrder    PharmacyOrder? @relation(fields: [pharmacyOrderId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model AssignmentEvent {
  id                  String       @id @default(cuid())
  customerOrderId     String
  pharmacyOrderId     String?
  requestedItemName   String
  requestedRouteKey   String
  requestedPharmacyName String?
  selectedProductName String
  selectedRouteKey    String
  selectedPharmacyName String
  strategy            String
  reason              String
  score               Float
  distanceKm          Float?
  customerOrder       CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  pharmacyOrder       PharmacyOrder? @relation(fields: [pharmacyOrderId], references: [id], onDelete: SetNull)
  createdAt           DateTime     @default(now())
}

model AdminNotification {
  id          String              @id @default(cuid())
  type        AdminNotificationType @default(PHARMACY_PENDING)
  title       String
  message     String
  pharmacyId  String?
  readAt      DateTime?
  pharmacy    Pharmacy?           @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

enum OrderStatus {
  PENDING
  PARTIALLY_CONFIRMED
  CONFIRMED
  READY
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PharmacyOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PrescriptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PharmacyStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum UserRole {
  ADMIN
  PHARMACY
}

enum AdminNotificationType {
  PHARMACY_PENDING
}
